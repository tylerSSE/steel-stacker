# =============================================================================
# Stage 1 (current): NO ENV VARS NEEDED. Leaderboard runs on localStorage.
# =============================================================================
#
# Stage 2 (Supabase + Turnstile): copy this file to .env.local and fill in
# the values. Vercel deployment gets them via the project dashboard:
# Project Settings → Environment Variables.
#
# These three are server-side (used inside /api routes — never expose to the
# browser). They give the API route admin access to write to the leaderboard.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
TURNSTILE_SECRET_KEY=
#
# These two are public — they ship to the browser bundle. Vite uses the VITE_
# prefix to mark vars that are safe to expose. The anon key is the Supabase
# read-only client key; the Turnstile site key is the public widget identifier.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_TURNSTILE_SITE_KEY=
